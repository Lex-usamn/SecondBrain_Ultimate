# ===========================================
# CONFIGURAÇÕES DO SECOND BRAIN ULTIMATE
# ===========================================
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commit o arquivo .env no git!

# --- LEX FLOW API ---
LEX_FLOW_BASE_URL=https://flow.lex-usamn.com.br
LEX_FLOW_USERNAME=seu_usuario_lex_flow
LEX_FLOW_PASSWORD=sua_senha_lex_flow
# Ou diretamente o token (se já tiver):
LEX_FLOW_TOKEN=

# --- OBSIDIAN VAULT ---
OBSIDIAN_VAULT_PATH=/Users/seu_usuario/SecondBrain_Ultimate/obsidian-vault
# No MacOS (Hackintosh): /Users/lex/...
# No Windows: C:\Users\lex\...

# --- CLAUDE CODE (AI ENGINE) ---
ANTHROPIC_API_KEY=sk-ant-...
# Obter em: https://console.anthropic.com/

# --- TELEGRAM BOT (FUTURO) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- DISCORD BOT (FUTURO) ---
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=

# --- YOUTUBE API (FUTURO) ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- CONFIGURAÇÕES GERAIS ---
TIMEZONE=America/Sao_Paulo
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL_MINUTES=30